{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^1.1.3",
    "gh-pages": "^4.0.0",
    "immer": "^11.1.4",
    "madge": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.3.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@pandacss/dev": "^0.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.11.18",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "scripts": {
    "panda": "panda codegen",
    "dev": "panda codegen && vite",
    "build": "panda codegen && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "predeploy": "pnpm build",
    "deploy": "cp dist/index.html dist/404.html && gh-pages -d dist"
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "src/features/**/*.{ts,tsx}",
          "src/shared/**/*.{ts,tsx}"
        ],
        "excludedFiles": [
          "**/__tests__/**",
          "**/__mocks__/**"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "recoil"
                  ],
                  "message": "Recoil 은 제거되었습니다. zustand 스토어(@store/*)를 사용하세요."
                },
                {
                  "group": [
                    "@store/*"
                  ],
                  "message": "Feature/Shared 레이어에서 store 직접 접근은 금지됩니다. Shell(src/pages/**/shells/)을 통해 props로 주입하세요."
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "https://kiimdohyun.github.io/KiimDoHyun-portfolio_window"
}
