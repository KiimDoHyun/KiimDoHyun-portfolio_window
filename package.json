{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^1.1.3",
    "gh-pages": "^4.0.0",
    "immer": "^11.1.4",
    "madge": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.4",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@craco/types": "^7.1.0",
    "@pandacss/dev": "^0.40.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.11.18",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "scripts": {
    "panda": "panda codegen",
    "start": "panda codegen && craco start",
    "build": "panda codegen && craco build",
    "test": "react-scripts test",
    "eject": "craco eject",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d build"
  },
  "jest": {
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@features/(.*)$": "<rootDir>/src/features/$1",
      "^@pages/(.*)$": "<rootDir>/src/pages/$1",
      "^@app/(.*)$": "<rootDir>/src/app/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@images/(.*)$": "<rootDir>/src/asset/images/$1",
      "^@styled-system/css$": "<rootDir>/src/__mocks__/styledSystemCss.js",
      "^@styled-system/(.*)$": "<rootDir>/src/styled-system/$1"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "src/features/**/*.{ts,tsx}",
          "src/shared/**/*.{ts,tsx}"
        ],
        "excludedFiles": [
          "**/__tests__/**",
          "**/__mocks__/**"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "recoil"
                  ],
                  "message": "Recoil 은 제거되었습니다. zustand 스토어(@store/*)를 사용하세요."
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "https://kiimdohyun.github.io/KiimDoHyun-portfolio_window"
}
